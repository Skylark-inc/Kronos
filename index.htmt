<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Kronos</title>

<link rel="icon" href="web-icon">
<link rel="apple-touch-icon" href="web-icon">

<style>
:root{
  color-scheme: dark;
  --bg:#050203;
  --card:#130609;
  --card2:#1c080d;
  --text:#f7e8ec;
  --muted:#b98a95;
  --red:#7f1022;
  --red2:#a31831;
  --border:#3a111a;
}

*{box-sizing:border-box}

body{
  margin:0;
  min-height:100vh;
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;
  background:
    radial-gradient(circle at top, #240812 0%, transparent 35%),
    linear-gradient(180deg,#070203,#020102);
  color:var(--text);
  display:flex;
  align-items:center;
  justify-content:center;
  padding:24px;
}

main{
  width:100%;
  max-width:620px;
  text-align:center;
}

.card{
  background:linear-gradient(180deg,var(--card2),var(--card));
  border:1px solid var(--border);
  border-radius:28px;
  padding:34px 24px;
  box-shadow:0 24px 80px rgba(0,0,0,.45);
}

h1{
  margin:0;
  font-size:42px;
  letter-spacing:.5px;
}

.eerie{
  margin:14px auto 28px;
  max-width:480px;
  color:var(--muted);
  line-height:1.5;
}

.buttons{
  display:grid;
  gap:14px;
}

a.button{
  display:block;
  text-decoration:none;
  color:#fff;
  background:linear-gradient(180deg,var(--red2),var(--red));
  border:1px solid #b9253f;
  border-radius:18px;
  padding:16px 18px;
  font-weight:700;
  transition:.2s ease;
}

a.button:hover{
  transform:translateY(-2px);
  filter:brightness(1.08);
}

.locked{
  display:none;
  color:#ffd6dd;
  background:#22070d;
  border:1px solid #651525;
  border-radius:18px;
  padding:16px;
  font-weight:700;
}

footer{
  margin-top:22px;
  color:#8d6670;
  font-size:13px;
}

@media(max-width:520px){
  h1{font-size:34px}
  .card{padding:28px 18px}
}
</style>
</head>

<body>
<main>
  <section class="card">
    <h1>Kronos</h1>
    <p class="eerie">
      Some albums are not lost. They are only waiting behind the quiet door.
    </p>

    <div id="buttons" class="buttons"></div>
    <div id="locked" class="locked">Kronos is not available right now</div>
  </section>

  <footer>©️Skylark <span id="year"></span></footer>
</main>

<script>
/*
  You found the wiring behind the wall.
  Kronos still keeps its own hours.
*/

const CONFIG_URL = "https://skylark-inc.github.io/kronos.json";

document.getElementById("year").textContent =
  Math.min(new Date().getFullYear(), 9999);

function kronosAvailable(){
  const hour = new Date().getHours();
  return hour < 7 || hour >= 19;
}

async function loadKronos(){
  const buttons = document.getElementById("buttons");
  const locked = document.getElementById("locked");

  if(!kronosAvailable()){
    buttons.style.display = "none";
    locked.style.display = "block";
    return;
  }

  try{
    const response = await fetch(CONFIG_URL, { cache: "no-store" });
    if(!response.ok) throw new Error("Kronos config failed");

    const data = await response.json();

    buttons.innerHTML = "";

    data.albums.forEach(item => {
      if(!item.enabled || !item.url) return;

      const link = document.createElement("a");
      link.className = "button";
      link.href = item.url;
      link.textContent = item.name;
      link.rel = "noopener";
      buttons.appendChild(link);
    });

    if(!buttons.children.length){
      locked.style.display = "block";
      locked.textContent = "Kronos is not available right now";
    }

  }catch(error){
    buttons.style.display = "none";
    locked.style.display = "block";
  }
}

loadKronos();
</script>
</body>
</html>
